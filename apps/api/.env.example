# Node API (Fastify HTTP + WebSocket). Validated with Zod on startup (Phase 2).
PORT=3001

# Postgres (Prisma) — matches docker-compose / root .env.example.
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel?schema=public

# Redis pub/sub bus + cache.
REDIS_URL=redis://localhost:6379

# Must match the secret Auth.js uses in `web` to sign JWTs (Phase 3).
JWT_SECRET=replace-with-a-long-random-string

# Allowed browser origin for CORS.
CORS_ORIGIN=http://localhost:3000
