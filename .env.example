# Shared local infra (consumed by docker-compose and by service .env files).
# Copy to `.env` and adjust as needed: `cp .env.example .env`

# --- Postgres ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel
POSTGRES_PORT=5432
# Used by Prisma (Node) and sqlx (Rust). Matches the docker-compose service.
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel?schema=public

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- AI enrichment (api, optional) ---
# On-demand alert analysis. Empty → deterministic heuristic fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Real on-chain events via Helius webhooks (api, optional) ---
# Point a Helius "Enhanced transactions" webhook at POST /webhooks/helius.
# If set, the webhook must send this exact value as its Authorization header.
HELIUS_WEBHOOK_AUTH=

# --- Ingestor source (EVENT_SOURCE) ---
# mock (default) | rpc (free WebSocket RPC) | yellowstone (paid Helius gRPC)
EVENT_SOURCE=mock
MOCK_EVENTS_PER_SEC=2

# rpc mode — FREE: a Helius/QuickNode free-tier key gives both URLs (same key).
# Auto-watches the wallet addresses from users' active rules (via DATABASE_URL).
# RPC_WATCH_ACCOUNTS is OPTIONAL extra addresses (e.g. programs) to always watch.
RPC_WS_URL=
RPC_HTTP_URL=
RPC_WATCH_ACCOUNTS=

# yellowstone mode — PAID: a Helius gRPC (Geyser) endpoint + key.
HELIUS_GRPC_URL=
HELIUS_API_KEY=
