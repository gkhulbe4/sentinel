{
  "name": "@sentinel/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "prisma generate",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "push": "dotenv -e ../../.env -- prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0"
  },
  "devDependencies": {
    "@sentinel/config": "workspace:*",
    "@types/node": "^22.10.0",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.17.0",
    "prisma": "^6.2.0",
    "typescript": "^5.7.0"
  }
}
